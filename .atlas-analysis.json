  "keyFeatures": [
    "Real-time X search using Grok's native x_search tool",
    "Handle monitoring with include/exclude filters",
    "Cross-platform research combining X and web search",
    "Data analysis with code interpreter for engagement statistics",
    "Structured JSON extraction with 5 built-in schemas",
    "Image and video understanding in posts",
    "Multiple Grok 4 model variants for speed vs depth tradeoffs"
  ],
  "publicApiSurface": [
    "grok_x.py <query> - Main command entry point",
    "--handles / -H - Monitor specific accounts",
    "--exclude / -E - Exclude specific accounts",
    "--from / --to - Date range filters",
    "--images / -i - Enable image understanding",
    "--videos / -v - Enable video understanding",
    "--web / -w - Add web search alongside X search",
    "--analyze / -a - Enable code interpreter for data analysis",
    "--extract SCHEMA - Extract structured JSON (sentiment, narrative, timeline, profiles, claims)",
    "--fast - Use grok-4-1-fast-non-reasoning model",
    "--deep - Use grok-4-0709 model",
    "--citations / -c - Print citation URLs",
    "--no-stream - Disable streaming output"
  ]
}
